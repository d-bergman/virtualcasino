{
  "rules": {
    "virtualCasino": {
      "familyCardRpg": {
        ".read": "auth != null",
        ".write": "auth != null",
        "users": {
          "$uid": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "state": {
          ".read": "auth != null",
          ".write": "auth != null",
          "onlineRooms": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    }
  }
}
